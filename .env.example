PORT=5000
NODE_ENV=development
MONGODB_URI=mongodb://127.0.0.1:27017/prepmate_ai
JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRES_IN=7d
GUEST_USER_ID=000000000000000000000001
CLIENT_ORIGIN=http://127.0.0.1:5173,http://localhost:5173
OPENAI_API_KEY=sk-your-openai-key
OPENAI_MODEL=gpt-5.5
OPENAI_COMMUNICATION_MODELS=gpt-5.5,gpt-5.5-pro,gpt-5.4,gpt-5.4-mini,gpt-5.4-nano
OPENAI_TRANSCRIPTION_MODEL=gpt-4o-mini-transcribe
OPENAI_TRANSCRIPTION_MODELS=gpt-4o-mini-transcribe,gpt-4o-transcribe
ALLOW_AI_FALLBACK=false
